# Copy this file to .env and fill in your key. Both main.py and
# handoff_demo.py load .env automatically (via python-dotenv), so you don't
# need to `export` anything by hand. Get a FREE key (no credit card) at:
#   https://aistudio.google.com/apikey
#
# Note: .env is gitignored so your real key never gets committed.
# Leave this template's value EMPTY - it is committed to the repo.
GEMINI_API_KEY=

# Optional: override the default model (gemini-2.5-flash) if Google's
# free-tier lineup changes and you hit a 429 with "limit: 0".
# GEMINI_MODEL=gemini-2.5-flash-lite
